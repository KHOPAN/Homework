<?xml version="1.0" encoding="utf-8"?>
<resources>
	<declare-styleable name="CardView">
		<attr format="boolean" name="anchorDividersToTitle" />
		<attr format="boolean" name="bottomDividerVisible" />
		<attr format="boolean" name="topDividerVisible" />
		<attr format="color" name="endIconTint" />
		<attr format="color" name="iconTint" />
		<attr format="reference" name="endIcon" />
		<attr format="reference" name="icon" />
		<attr format="string" name="summary" />
		<attr format="string" name="title" />
		<attr name="cardLocation">
			<flag name="top" value="0x01" />
			<flag name="middle" value="0x00" />
			<flag name="bottom" value="0x02" />
			<flag name="bottomDividerPreferred" value="0x04" />
			<flag name="topDividerPreferred" value="0x00" />
		</attr>
	</declare-styleable>
	<declare-styleable name="CheckableCardView">
		<attr format="boolean" name="checkboxState" />
		<attr format="boolean" name="checkboxVisible" />
		<attr name="checkboxType">
			<flag name="single" value="0x00" />
			<flag name="multiple" value="0x01" />
		</attr>
	</declare-styleable>
	<declare-styleable name="SwitchableCardView">
		<attr format="boolean" name="switchDividerVisible" />
		<attr format="boolean" name="switchState" />
		<attr format="boolean" name="switchVisible" />
	</declare-styleable>
	<string name="dialog_button_negative">Cancel</string>
	<string name="dialog_button_positive">Done</string>
</resources>
