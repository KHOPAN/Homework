<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:paddingHorizontal="10dp">
	<dev.oneuiproject.oneui.widget.RoundedFrameLayout
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1.0">
		<androidx.core.widget.NestedScrollView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:fillViewport="true"
			android:overScrollMode="always">
			<dev.oneuiproject.oneui.widget.RoundedLinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<dev.oneuiproject.oneui.widget.RoundedLinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/oui_des_background_color"
					android:orientation="vertical">
					<com.khopan.core.view.card.CardView
						android:id="@+id/title_view"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						app:title="@string/new_assignment_title"
						app:topDividerVisible="false" />

				</dev.oneuiproject.oneui.widget.RoundedLinearLayout>
				<dev.oneuiproject.oneui.widget.Separator
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

				<dev.oneuiproject.oneui.widget.RoundedLinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/oui_des_background_color"
					android:orientation="vertical">
					<com.khopan.core.view.card.CardView
						android:id="@+id/deadline_date_view"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						app:title="@string/new_assignment_deadline_date"
						app:topDividerVisible="false" />

					<com.khopan.core.view.card.CardView
						android:id="@+id/deadline_time_view"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						app:title="@string/new_assignment_deadline_time" />

				</dev.oneuiproject.oneui.widget.RoundedLinearLayout>
			</dev.oneuiproject.oneui.widget.RoundedLinearLayout>
		</androidx.core.widget.NestedScrollView>
	</dev.oneuiproject.oneui.widget.RoundedFrameLayout>
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal">
		<Button android:id="@+id/cancel_button"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginVertical="8dp"
			android:layout_weight="1.0"
			android:clickable="true"
			android:focusable="true"
			android:text="@string/new_assignment_cancel"
			android:textColor="?attr/colorPrimary"
			android:theme="@style/OneUI.ContainedTransparentButtonTheme"
			style="@style/OneUI.ContainedButton" />

		<Button android:id="@+id/add_button"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginVertical="8dp"
			android:layout_weight="1.0"
			android:clickable="true"
			android:focusable="true"
			android:text="@string/new_assignment_add"
			android:textColor="?attr/colorPrimary"
			android:theme="@style/OneUI.ContainedTransparentButtonTheme"
			style="@style/OneUI.ContainedButton" />

	</LinearLayout>
</LinearLayout>
