<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
	package="com.sec.sesl.khopan.homework">
	<application android:icon="@mipmap/launcher_icon"
		android:label="@string/applicationName"
		android:roundIcon="@mipmap/launcher_icon"
		android:supportsRtl="true"
		android:theme="@style/OneUITheme">
		<meta-data android:name="SamsungBasicInteraction"
			android:value="SEP10" />

		<meta-data android:name="com.samsung.android.icon_container.has_icon_container"
			android:value="true" />

		<meta-data android:name="com.samsung.android.icon_container.feature_appicon"
			android:value="ADAPTIVEICON_SHADOW" />

		<meta-data android:name="theming-meta"
			android:value="samsung_metadata" />

		<meta-data android:name="theming-meta-xml"
			android:value="@xml/samsung_metadata" />

		<activity android:exported="true"
			android:launchMode="singleTop"
			android:name="com.khopan.homework.HomeworkApplication">
			<meta-data android:name="com.sec.android.app.launcher.icon_theme"
				android:value="themeColor" />

			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<action android:name="android.intent.action.SEARCH" />
				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>
		</activity>
	</application>
</manifest>
